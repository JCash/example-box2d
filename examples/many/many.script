function on_input(self, action_id, action)
	if action_id == hash("touch") and action.pressed then

		if self.version_v2 then
			spawn_v2(self, self.objecttype, vmath.vector3(action.x, action.y, 0))
			add_triangle_v2(self, self.last)
		else
			spawn_v3(self, self.objecttype, vmath.vector3(action.x, action.y, 0))
			add_triangle_v3(self, self.last)
		end

	elseif action_id == hash("JUMP") and action.pressed then
		----print("JUMP")

		local time_start = socket.gettime()

		local count = 0
		for _, body in ipairs(self.boxes) do
			local pos = b2d.body.get_position(body)

			-- same for both api's
			b2d.body.apply_linear_impulse(body, vmath.vector3(300,200,0), pos + vmath.vector3(16,16,0))

			count = count + 1
		end


		local time_end = socket.gettime()
		print("Appled impulse to", count, "bodies in", (time_end - time_start) * 1000, "ms")

	elseif action_id == hash("LEFT") and action.pressed then
		--print(action_id)

		local body = self.last
		if body then
			local velocity = b2d.body.get_linear_velocity(body)
			b2d.body.set_linear_velocity(body, velocity * 0.5)
		end

	elseif action_id == hash("RIGHT") and action.pressed then
		--print(action_id)

		local body = self.last
		if body then
			local velocity = b2d.body.get_angular_velocity(body)
			if velocity < 0.01 then
				velocity = -1.0
			end
			b2d.body.set_angular_velocity(body, velocity * 20.0)
		end
	end
end

