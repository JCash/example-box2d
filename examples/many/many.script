
local function spawn_v2(self, objecttype, position)
	--print("Spawn", "box", position)
	if objecttype == "box" then
		local id = factory.create("factories#factory_" .. objecttype, position)
		if b2d then
			local url = msg.url(nil, id, "collisionobject")
			local body = b2d.get_body(url)

			--print("is active: ", b2d.body.is_active(body))
			b2d.body.set_active(body, true)
			--print("get velocity (1): ", b2d.body.get_linear_velocity(body))
			b2d.body.set_linear_velocity(body, vmath.vector3(0, 10, 0))
			--print("get velocity (2): ", b2d.body.get_linear_velocity(body))

			--b2d.body.dump(dump)
			--print("next", b2d.body.get_next(body))
			table.insert(self.boxes, body)
			table.insert(self.ids, id)

			self.last = body
		end
	end
end

local function spawn_v3(self, objecttype, position)
	--print("Spawn", "box", position)
	if objecttype == "box" then
		local id = factory.create("factories#factory_" .. objecttype, position)
		if b2d then
			local url = msg.url(nil, id, "collisionobject")
			local body = b2d.get_body(url)

			--b2d.body.set_active(body, true)
			b2d.body.set_linear_velocity(body, vmath.vector3(0, 10, 0))
			table.insert(self.boxes, body)
			table.insert(self.ids, id)

			self.last = body
		end
	end
end

local function add_triangle_v2(self, body)
	local fixtures = b2d.body.get_fixtures(body)
	pprint("FIXTURES:", fixtures)
	b2d.fixture.set_restitution(body, 1, 1.0)

	local triangle = b2d.body.create_fixture(body, {
	    density = 1.0,
	    friction = 0.3,
	    shape = {
	        type = b2d.shape.SHAPE_TYPE_POLYGON,
	        vertices = {
	            vmath.vector3(-16, -16, 0),
	            vmath.vector3( 16, -16, 0),
	            vmath.vector3(  0,  16, 0),
	        },
	    },
	})
	pprint("TRIANGLE", triangle)
end

local function add_triangle_v3(self, body)
	local shapes = b2d.body.get_shapes(body)
	pprint("SHAPES:", shapes)

	b2d.shape.set_restitution(body, 1, 1.0)

	local triangle = b2d.body.create_shape(body, {
	  density = 1.0,
	  friction = 0.3,
	  shape = {
	      type = b2d.shape.SHAPE_TYPE_POLYGON,
	      vertices = {
	          vmath.vector3(-16, -16, 0),
	          vmath.vector3( 16, -16, 0),
	          vmath.vector3(  0,  16, 0),
	      },
	  },
	})
	pprint("TRIANGLE", triangle)
end

function init(self)
	msg.post(".", "acquire_input_focus")

	self.version = b2d.get_version()
	self.version_v2 = self.version.major == 2

	print("**************************************************")
	pprint("Using Box2D:", self.version.major, self.version.middle, self.version.minor)
	print("**************************************************")

	self.objecttype = "box"
	label.set_text("go#label", "type: " .. self.objecttype)

	self.boxes = {}
	if b2d then
		self.world = b2d.get_world()
	else
		print("Found no Box2D support!")
	end

	self.last = nil
	self.ids = {}

	local step = 40
	for y=1,15 do
		local yy = 100 + y * step
		for x=1,15 do
			local xx = 100 + x * step

			if self.version_v2 then
				spawn_v2(self, "box", vmath.vector3(xx, yy, 0))
			else
				spawn_v3(self, "box", vmath.vector3(xx, yy, 0))
			end
		end
	end

end

